<!doctype html>
<html lang="{{ request.locale.iso_code }}" dir="ltr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="theme-color" content="{{ settings.color_espresso | default: '#51361f' }}">
  <link rel="canonical" href="{{ canonical_url }}">
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>{{ page_title }}{% if current_tags %} &ndash; {{ 'general.tagged_items' | t }}{% endif %}{% if current_page != 1 %} &ndash; {{ 'general.page' | t }} {{ current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}</title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {%- liquid
    if request.page_type == 'product'
      assign og_type = 'product'
      assign og_title = product.title | escape
      assign og_desc = product.description | strip_html | truncatewords: 30 | escape
      assign og_image = product.featured_image | image_url: width: 1200
    elsif request.page_type == 'collection'
      assign og_type = 'website'
      assign og_title = collection.title | escape
      assign og_desc = collection.description | strip_html | truncatewords: 30 | escape
      assign og_image = collection.image | image_url: width: 1200
    elsif request.page_type == 'article'
      assign og_type = 'article'
      assign og_title = article.title | escape
      assign og_desc = article.excerpt_or_content | strip_html | truncatewords: 30 | escape
      assign og_image = article.image | image_url: width: 1200
    else
      assign og_type = 'website'
      assign og_title = page_title | escape
      assign og_desc = page_description | escape
      assign og_image = settings.og_image | image_url: width: 1200
    endif
  -%}
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:type" content="{{ og_type }}">
  <meta property="og:title" content="{{ og_title | default: page_title | escape }}">
  <meta property="og:url" content="{{ canonical_url }}">
  {%- if og_desc != blank -%}<meta property="og:description" content="{{ og_desc }}">{%- endif -%}
  {%- if og_image != blank -%}<meta property="og:image" content="https:{{ og_image }}">{%- endif -%}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ og_title | default: page_title | escape }}">
  {%- if og_desc != blank -%}<meta name="twitter:description" content="{{ og_desc }}">{%- endif -%}
  {%- if og_image != blank -%}<meta name="twitter:image" content="https:{{ og_image }}">{%- endif -%}


  {{ content_for_header }}

  <link rel="preload" href="{{ 'clow.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="{{ 'clow.css' | asset_url }}"></noscript>

  <style>
    :root {
      --espresso: {{ settings.color_espresso | default: '#51361f' }};
      --espresso-deep: {{ settings.color_espresso_deep | default: '#2e1d0e' }};
    }
  </style>

  <script>
    window.ClowSettings = {
      moneyFormat: {{ shop.money_format | json }},
      samplesThreshold: {{ settings.samples_threshold | default: 39 }},
      freeShipThreshold: {{ settings.free_ship_threshold | default: 39 }},
      routes: {
        cart: {{ routes.cart_url | json }},
        cartAdd: '/cart/add.js',
        cartChange: '/cart/change.js'
      }
    };
    window.ClowStrings = {
      addToCart: {{ 'product.add_to_cart' | t | json }},
      added: {{ 'product.added' | t | json }},
      soldOut: {{ 'product.sold_out' | t | json }},
      cartEmpty: {{ 'cart.empty' | t | json }},
      samplesRemainA: {{ 'cart.samples_remain_a' | t | json }},
      samplesRemainB: {{ 'cart.samples_remain_b' | t | json }},
      samplesUnlocked: {{ 'cart.samples_unlocked' | t | json }},
      copied: {{ 'account.copied' | t | json }},
      quizRoutineLine: {{ 'quiz.routine_line' | t | json }},
      quizResultSub: {{ 'quiz.result_sub' | t | json }},
      quizEmailSent: {{ 'quiz.email_sent' | t | json }}
    };
  </script>
</head>

<body class="clow-type template-{{ request.page_type | handle }}">
  <a class="visually-hidden" href="#MainContent">{{ 'general.skip' | t | default: 'Skip to content' }}</a>

  {%- section 'header' -%}

  <main id="MainContent" class="page-fade" role="main">
    {{ content_for_layout }}
  </main>

  {%- section 'footer' -%}

  {%- comment -%} Cart drawer {%- endcomment -%}
  <div id="clow-cart-overlay" class="cart-drawer-overlay"></div>
  <aside id="clow-cart-drawer" class="cart-drawer" aria-label="{{ 'cart.title' | t }}">
    <div class="cart-drawer__head">
      <span class="cart-drawer__title">{{ 'cart.title_drawer' | t }}</span>
      <button class="header-icon" data-cart-close aria-label="{{ 'general.close' | t }}">{% render 'icon', icon: 'x', size: 22 %}</button>
    </div>
    <div class="cart-drawer__samples" data-samples-bar>
      <div class="samples-bar__label" data-samples-label></div>
      <div class="samples-bar__track"><div class="samples-bar__fill" data-samples-fill></div></div>
    </div>
    <div id="clow-cart-drawer-body" class="cart-drawer__body"></div>
    <div id="clow-cart-drawer-foot" class="cart-drawer__foot" hidden>
      <div class="cart-drawer__sub-row">
        <span class="label">{{ 'cart.subtotal' | t }}</span>
        <span class="val" data-drawer-subtotal></span>
      </div>
      <div class="cart-drawer__pts">{{ 'cart.points_earn' | t }} <b><span data-drawer-points>0</span> {{ 'cart.points_unit' | t }}</b></div>
      <a href="{{ routes.cart_url }}" class="btn btn--lg btn--full">
        {{ 'cart.checkout' | t }} {% render 'icon', icon: 'arrow-right', size: 16 %}
      </a>
    </div>
  </aside>

  {%- comment -%} Toast {%- endcomment -%}
  <div id="clow-toast" class="toast" aria-live="polite" role="status">
    {% render 'icon', icon: 'check', size: 15 %}
    <span class="toast__name"></span>
  </div>

  <script src="{{ 'clow.js' | asset_url }}" defer></script>
</body>
</html>
