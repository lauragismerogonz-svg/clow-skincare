<footer class="site-footer">
  <div class="footer-grid">
    <div>
      <a class="footer-wordmark" href="{{ routes.root_url }}">{{ section.settings.logo_text | default: shop.name }}</a>
      <p class="footer-tag">{{ section.settings.tagline | default: 'footer.tagline' | t }}</p>
      <div class="footer-social">
        {%- if settings.instagram_url != blank -%}
          <a href="{{ settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">{% render 'icon', icon: 'instagram', size: 17 %}</a>
        {%- endif -%}
        {%- if settings.tiktok_url != blank -%}
          <a href="{{ settings.tiktok_url }}" target="_blank" rel="noopener" aria-label="TikTok">{% render 'icon', icon: 'tiktok', size: 17 %}</a>
        {%- endif -%}
        {%- if settings.pinterest_url != blank -%}
          <a href="{{ settings.pinterest_url }}" target="_blank" rel="noopener" aria-label="Pinterest">{% render 'icon', icon: 'pinterest', size: 17 %}</a>
        {%- endif -%}
        {%- if settings.email_address != blank -%}
          <a href="mailto:{{ settings.email_address }}" aria-label="Email">{% render 'icon', icon: 'mail', size: 17 %}</a>
        {%- endif -%}
      </div>
    </div>

    <div>
      <div class="footer-col__title">{{ 'footer.col_shop' | t }}</div>
      <div class="footer-col__links">
        <a href="{{ section.settings.url_best_sellers | default: routes.all_products_collection_url }}">{{ 'footer.links.best_sellers' | t }}</a>
        <a href="{{ section.settings.url_routines | default: routes.collections_url }}">{{ 'footer.links.routine' | t }}</a>
        <a href="{{ section.settings.url_products | default: routes.all_products_collection_url }}">{{ 'footer.links.products' | t }}</a>
        <a href="{{ section.settings.url_quiz | default: '/pages/quiz' }}">{{ 'footer.links.quiz' | t }}</a>
        <a href="{{ section.settings.url_gift | default: '/products/carte-cadeau' }}">{{ 'footer.links.gift' | t }}</a>
      </div>
    </div>

    <div>
      <div class="footer-col__title">{{ 'footer.col_help' | t }}</div>
      <div class="footer-col__links">
        <a href="{{ section.settings.url_help_steps | default: '/pages/routine-coreenne' }}">{{ 'footer.links.help_steps' | t }}</a>
        <a href="{{ section.settings.url_help_glass | default: '/pages/glass-skin' }}">{{ 'footer.links.help_glass' | t }}</a>
        <a href="{{ section.settings.url_quiz | default: '/pages/quiz-skincare' }}">{{ 'footer.links.help_type' | t }}</a>
        <a href="{{ section.settings.url_contact | default: '/pages/contact' }}">{{ 'footer.links.contact' | t }}</a>
      </div>
    </div>

    <div>
      <div class="footer-col__title">{{ 'footer.col_about' | t }}</div>
      <div class="footer-col__links">
        <a href="{{ section.settings.url_terms | default: '/policies/terms-of-service' }}">{{ 'footer.links.terms' | t }}</a>
        <a href="{{ section.settings.url_shipping | default: '/policies/shipping-policy' }}">{{ 'footer.links.shipping' | t }}</a>
        <a href="{{ section.settings.url_legal | default: '/policies/legal-notice' }}">{{ 'footer.links.legal' | t }}</a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <span>{{ 'footer.legal' | t }}</span>
    {%- if localization.available_languages.size > 1 -%}
      {%- form 'localization', id: 'lang-form-footer' -%}
        <select class="lang-select lang-select--footer" name="locale_code" onchange="this.form.submit()" aria-label="Langue">
          {%- for lang in localization.available_languages -%}
            <option value="{{ lang.iso_code }}"{% if lang.iso_code == localization.language.iso_code %} selected{% endif %}>{{ lang.endonym_name | capitalize }}</option>
          {%- endfor -%}
        </select>
      {%- endform -%}
    {%- endif -%}
    <span>{{ 'footer.pay' | t }}</span>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "logo_text", "label": "Logo wordmark", "default": "Clow" },
    { "type": "textarea", "id": "tagline", "label": "Tagline", "info": "Leave blank to use the translated default." },
    { "type": "header", "content": "Shop column" },
    { "type": "url", "id": "url_best_sellers", "label": "Best Sellers link" },
    { "type": "url", "id": "url_routines", "label": "Routines link" },
    { "type": "url", "id": "url_products", "label": "Products link" },
    { "type": "url", "id": "url_quiz", "label": "Quiz link" },
    { "type": "url", "id": "url_gift", "label": "Gift card link" },
    { "type": "header", "content": "Help column" },
    { "type": "url", "id": "url_help_steps", "label": "Korean routine steps page" },
    { "type": "url", "id": "url_help_glass", "label": "Glass skin page" },
    { "type": "url", "id": "url_contact", "label": "Contact page" },
    { "type": "header", "content": "About column" },
    { "type": "url", "id": "url_terms", "label": "Terms of service" },
    { "type": "url", "id": "url_shipping", "label": "Shipping & returns" },
    { "type": "url", "id": "url_legal", "label": "Legal / Mentions légales" }
  ]
}
{% endschema %}
