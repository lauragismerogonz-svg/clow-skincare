{%- liquid
  assign col_demaq   = collections['demaquillant-nettoyant']
  assign col_toner   = collections['toner']
  assign col_eye     = collections['serum-pour-les-yeux']
  assign col_serum   = collections['serum-2']
  assign col_creme   = collections['creme']
  assign col_sun     = collections['creme-solaire']
  assign col_gommage = collections['gommage-masques']
  assign col_levres  = collections['levres']
-%}

<section class="quiz" data-qd-wrap>
  <div class="quiz__wrap" id="qd-wrap">

    <div class="quiz-card" id="qd-card">
      <div class="quiz-card__top">
        <p class="eyebrow">{{ 'quiz.eyebrow' | t }}</p>
        <span class="quiz-card__counter" id="qd-counter">1 / 14</span>
      </div>
      <div class="quiz-progress">
        <div class="quiz-progress__fill" id="qd-bar"></div>
      </div>

      <div id="qd-steps">

        <!-- 0 : Bienvenue -->
        <div data-qd-step="0" data-qd-type="info">
          <h2 class="quiz-question">{{ 'quiz.qd.s0_q' | t }}</h2>
          <p class="qd-hint">{{ 'quiz.qd.s0_hint' | t }}</p>
          <div class="qd-cta"><button class="btn" type="button" data-qd-next>{{ 'quiz.qd.next' | t }}</button></div>
        </div>

        <!-- 1 : Prénom -->
        <div data-qd-step="1" data-qd-type="text" hidden>
          <h2 class="quiz-question">{{ 'quiz.qd.s1_q' | t }}</h2>
          <input class="qd-input" type="text" id="qd-name-input" placeholder="{{ 'quiz.qd.s1_placeholder' | t }}" minlength="2" autocomplete="given-name">
          <div class="qd-cta"><button class="btn" type="button" data-qd-next>{{ 'quiz.qd.next' | t }}</button></div>
        </div>

        <!-- 2 : Âge -->
        <div data-qd-step="2" data-qd-type="number" hidden>
          <h2 class="quiz-question">{{ 'quiz.qd.s2_q_a' | t }} <span id="qd-name-disp"></span>{{ 'quiz.qd.s2_q_b' | t }}</h2>
          <input class="qd-input" type="number" id="qd-age-input" placeholder="{{ 'quiz.qd.s2_placeholder' | t }}" min="10" max="100">
          <div class="qd-cta"><button class="btn" type="button" data-qd-next>{{ 'quiz.qd.next' | t }}</button></div>
        </div>

        <!-- 3 : Genre -->
