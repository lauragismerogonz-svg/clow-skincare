          <h2 class="quiz-question">{{ 'quiz.qd.s3_q' | t }}</h2>
          <div class="quiz-options">
            <button class="quiz-option" type="button" data-qd-choice>{{ 'quiz.qd.s3_a1' | t }} <span class="quiz-option__arrow">{% render 'icon', icon: 'arrow-right', size: 18 %}</span></button>
            <button class="quiz-option" type="button" data-qd-choice>{{ 'quiz.qd.s3_a2' | t }} <span class="quiz-option__arrow">{% render 'icon', icon: 'arrow-right', size: 18 %}</span></button>
