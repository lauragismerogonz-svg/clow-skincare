{%- liquid
  assign collection = collections[section.settings.collection]
  assign limit = section.settings.product_limit | default: 6
-%}
<section class="section section--alt">
  <div class="page-width">
    <div class="section-head">
      <div>
        <p class="eyebrow">{{ section.settings.eyebrow | default: 'home.best_eyebrow' | t }}</p>
        <h2 class="section-head__title">{{ section.settings.heading | default: 'home.best_h' | t }}</h2>
      </div>
      {%- if collection != blank -%}
        <a class="btn btn--text" href="{{ collection.url }}">{{ 'home.best_all' | t }} {% render 'icon', icon: 'arrow-right', size: 15 %}</a>
      {%- else -%}
        <a class="btn btn--text" href="{{ routes.all_products_collection_url }}">{{ 'home.best_all' | t }} {% render 'icon', icon: 'arrow-right', size: 15 %}</a>
      {%- endif -%}
    </div>

    <div class="product-grid">
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for product in collection.products limit: limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for product in collections.all.products limit: limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_limit", "label": "Number of products", "min": 3, "max": 12, "step": 3, "default": 6 }
  ],
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}
