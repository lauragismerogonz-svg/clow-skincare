    { "type": "url", "id": "url_hydra", "label": "Hydration collection" },
    { "type": "url", "id": "url_imp", "label": "Anti-blemish collection" },
    { "type": "url", "id": "url_age", "label": "Anti-age collection" },
    { "type": "url", "id": "url_glass", "label": "Glass Skin collection" },
    { "type": "url", "id": "url_sens", "label": "Sensitive collection" },
    { "type": "header", "content": "Symptom links" },
    { "type": "url", "id": "url_acne", "label": "Acné & Imperfections" },
    { "type": "url", "id": "url_eclat", "label": "Éclat & Taches" },
    { "type": "url", "id": "url_hydra_symp", "label": "Hydratation & Barrière" },
    { "type": "url", "id": "url_age_symp", "label": "Anti-âge & Fermeté" },
    { "type": "url", "id": "url_sens_symp", "label": "Peau Sensible" },
    { "type": "header", "content": "Category links" },
    { "type": "url", "id": "url_cleansers", "label": "Cleansers collection" },
    { "type": "url", "id": "url_toners", "label": "Toners collection" },
    { "type": "url", "id": "url_serums", "label": "Serums collection" },
    { "type": "url", "id": "url_creams", "label": "Creams collection" },
    { "type": "url", "id": "url_spf", "label": "SPF collection" },
    { "type": "url", "id": "url_masks", "label": "Masks collection" },
    { "type": "url", "id": "url_lips", "label": "Lips collection" },
    { "type": "url", "id": "url_hair", "label": "Hair collection" },
    { "type": "url", "id": "url_base", "label": "Base/Foundation collection" }
  ]
}
{% endschema %}
