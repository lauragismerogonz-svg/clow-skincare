{%- liquid
  assign routines = 'hydra,imp,age,glass,sens' | split: ','
  assign routine_urls = section.settings.url_hydra | default: '' | append: '||' | append: section.settings.url_imp | default: '' | append: '||' | append: section.settings.url_age | default: '' | append: '||' | append: section.settings.url_glass | default: '' | append: '||' | append: section.settings.url_sens | default: ''
  assign cat_keys = 'cleansers,toners,serums,creams,spf,masks,lips,hair,base' | split: ','
-%}

<header class="site-header">
  {%- if section.settings.show_announcement -%}
    <div class="announcement-bar">
      {{ section.settings.announcement_text | default: 'header.promo' | t }}
    </div>
  {%- endif -%}

  <div class="header-frost">
    <div class="header-bar">
      <button class="header-burger" data-mobile-nav-open aria-label="{{ 'general.menu' | t }}">
        {% render 'icon', icon: 'menu', size: 22 %}
      </button>

      <a class="header-logo" href="{{ routes.root_url }}">{{ section.settings.logo_text | default: shop.name }}</a>

      <nav class="header-nav" aria-label="{{ 'general.menu' | t }}">
        <div class="nav-item">
          <a class="nav-link" href="{{ section.settings.url_best_sellers | default: routes.all_products_collection_url }}">{{ 'header.nav.best_sellers' | t }}</a>
        </div>

        <div class="nav-item">
          <a class="nav-link" href="{{ section.settings.url_hydra | default: routes.collections_url }}">
            {{ 'header.nav.routine' | t }} {% render 'icon', icon: 'chevron-down', size: 14 %}<span class="chev"></span>
          </a>
          <div class="nav-dropdown">
            <div class="nav-dropdown__inner">
              <a class="nav-dropdown__link" href="{{ section.settings.url_hydra | default: routes.collections_url }}">
                <span class="routine-dot dot-hydra"></span>{{ 'header.routines.hydra' | t }}
              </a>
              <a class="nav-dropdown__link" href="{{ section.settings.url_imp | default: routes.collections_url }}">
                <span class="routine-dot dot-imp"></span>{{ 'header.routines.imp' | t }}
              </a>
              <a class="nav-dropdown__link" href="{{ section.settings.url_age | default: routes.collections_url }}">
                <span class="routine-dot dot-age"></span>{{ 'header.routines.age' | t }}
              </a>
              <a class="nav-dropdown__link" href="{{ section.settings.url_glass | default: routes.collections_url }}">
                <span class="routine-dot dot-glass"></span>{{ 'header.routines.glass' | t }}
              </a>
              <a class="nav-dropdown__link" href="{{ section.settings.url_sens | default: routes.collections_url }}">
                <span class="routine-dot dot-sens"></span>{{ 'header.routines.sens' | t }}
              </a>
            </div>
          </div>
        </div>

        <div class="nav-item">
          <a class="nav-link" href="{{ routes.all_products_collection_url }}">
            {{ 'header.nav.products' | t }} {% render 'icon', icon: 'chevron-down', size: 14 %}<span class="chev"></span>
          </a>
          <div class="nav-dropdown">
            <div class="nav-dropdown__inner">
              <a class="nav-dropdown__link" href="{{ section.settings.url_cleansers | default: routes.all_products_collection_url }}">{{ 'header.categories.cleansers' | t }}</a>
              <a class="nav-dropdown__link" href="{{ section.settings.url_toners | default: routes.all_products_collection_url }}">{{ 'header.categories.toners' | t }}</a>
              <a class="nav-dropdown__link" href="{{ section.settings.url_serums | default: routes.all_products_collection_url }}">{{ 'header.categories.serums' | t }}</a>
              <a class="nav-dropdown__link" href="{{ section.settings.url_creams | default: routes.all_products_collection_url }}">{{ 'header.categories.creams' | t }}</a>
              <a class="nav-dropdown__link" href="{{ section.settings.url_spf | default: routes.all_products_collection_url }}">{{ 'header.categories.spf' | t }}</a>
              <a class="nav-dropdown__link" href="{{ section.settings.url_masks | default: routes.all_products_collection_url }}">{{ 'header.categories.masks' | t }}</a>
              <a class="nav-dropdown__link" href="{{ section.settings.url_lips | default: routes.all_products_collection_url }}">{{ 'header.categories.lips' | t }}</a>
              <a class="nav-dropdown__link" href="{{ section.settings.url_hair | default: routes.all_products_collection_url }}">{{ 'header.categories.hair' | t }}</a>
              <a class="nav-dropdown__link" href="{{ section.settings.url_base | default: routes.all_products_collection_url }}">{{ 'header.categories.base' | t }}</a>
            </div>
          </div>
        </div>

        <div class="nav-item">
          <a class="nav-link nav-link--cta" href="{{ section.settings.url_quiz | default: routes.root_url | append: 'pages/quiz' }}">{{ 'header.nav.quiz' | t }}</a>
        </div>

        <div class="nav-item">
          <a class="nav-link" href="{{ section.settings.url_gift | default: routes.root_url | append: 'products/carte-cadeau' }}">{{ 'header.nav.gift' | t }}</a>
        </div>
      </nav>

      <div class="header-actions">
        <a class="header-icon" href="{{ routes.search_url }}" aria-label="{{ 'header.nav.search' | t }}">{% render 'icon', icon: 'search', size: 20 %}</a>
        <a class="header-icon" href="{{ routes.account_url }}" aria-label="{{ 'header.nav.account' | t }}">{% render 'icon', icon: 'user', size: 20 %}</a>
        <button class="header-icon" data-cart-open aria-label="{{ 'header.nav.cart' | t }}">
          {% render 'icon', icon: 'shopping-bag', size: 20 %}
          <span class="cart-count" data-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
        </button>
      </div>
    </div>
  </div>
</header>

{%- comment -%} Mobile nav drawer {%- endcomment -%}
<div id="clow-mobile-nav-overlay" class="mobile-nav-overlay"></div>
<aside id="clow-mobile-nav" class="mobile-nav" aria-label="{{ 'general.menu' | t }}">
  <div class="mobile-nav__head">
    <span class="mobile-nav__title">{{ 'general.menu' | t }}</span>
    <button class="header-icon" data-mobile-nav-close aria-label="{{ 'general.close' | t }}">{% render 'icon', icon: 'x', size: 22 %}</button>
  </div>
  <div class="mobile-nav__body">
    <a class="mobile-nav__link" href="{{ section.settings.url_best_sellers | default: routes.all_products_collection_url }}">{{ 'header.nav.best_sellers' | t }}</a>
    <a class="mobile-nav__link" href="{{ section.settings.url_quiz | default: routes.root_url | append: 'pages/quiz' }}">{{ 'header.nav.quiz' | t }}</a>
    <a class="mobile-nav__link" href="{{ section.settings.url_gift | default: routes.root_url | append: 'products/carte-cadeau' }}">{{ 'header.nav.gift' | t }}</a>

    <div class="mobile-nav__group">{{ 'header.nav.routine' | t }}</div>
    <a class="mobile-nav__sub" href="{{ section.settings.url_hydra | default: routes.collections_url }}"><span class="routine-dot dot-hydra"></span>{{ 'header.routines.hydra' | t }}</a>
    <a class="mobile-nav__sub" href="{{ section.settings.url_imp | default: routes.collections_url }}"><span class="routine-dot dot-imp"></span>{{ 'header.routines.imp' | t }}</a>
    <a class="mobile-nav__sub" href="{{ section.settings.url_age | default: routes.collections_url }}"><span class="routine-dot dot-age"></span>{{ 'header.routines.age' | t }}</a>
    <a class="mobile-nav__sub" href="{{ section.settings.url_glass | default: routes.collections_url }}"><span class="routine-dot dot-glass"></span>{{ 'header.routines.glass' | t }}</a>
    <a class="mobile-nav__sub" href="{{ section.settings.url_sens | default: routes.collections_url }}"><span class="routine-dot dot-sens"></span>{{ 'header.routines.sens' | t }}</a>

    <div class="mobile-nav__group">{{ 'header.nav.products' | t }}</div>
    <a class="mobile-nav__sub" href="{{ section.settings.url_cleansers | default: routes.all_products_collection_url }}">{{ 'header.categories.cleansers' | t }}</a>
    <a class="mobile-nav__sub" href="{{ section.settings.url_toners | default: routes.all_products_collection_url }}">{{ 'header.categories.toners' | t }}</a>
    <a class="mobile-nav__sub" href="{{ section.settings.url_serums | default: routes.all_products_collection_url }}">{{ 'header.categories.serums' | t }}</a>
    <a class="mobile-nav__sub" href="{{ section.settings.url_creams | default: routes.all_products_collection_url }}">{{ 'header.categories.creams' | t }}</a>
    <a class="mobile-nav__sub" href="{{ section.settings.url_spf | default: routes.all_products_collection_url }}">{{ 'header.categories.spf' | t }}</a>
    <a class="mobile-nav__sub" href="{{ section.settings.url_masks | default: routes.all_products_collection_url }}">{{ 'header.categories.masks' | t }}</a>
    <a class="mobile-nav__sub" href="{{ section.settings.url_lips | default: routes.all_products_collection_url }}">{{ 'header.categories.lips' | t }}</a>
    <a class="mobile-nav__sub" href="{{ section.settings.url_hair | default: routes.all_products_collection_url }}">{{ 'header.categories.hair' | t }}</a>
    <a class="mobile-nav__sub" href="{{ section.settings.url_base | default: routes.all_products_collection_url }}">{{ 'header.categories.base' | t }}</a>
  </div>
</aside>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "header", "content": "Branding" },
    { "type": "text", "id": "logo_text", "label": "Logo wordmark", "default": "Clow" },
    { "type": "header", "content": "Announcement bar" },
    { "type": "checkbox", "id": "show_announcement", "label": "Show announcement bar", "default": true },
    { "type": "text", "id": "announcement_text", "label": "Announcement text", "info": "Leave blank to use the translated default." },
    { "type": "header", "content": "Main links" },
    { "type": "url", "id": "url_best_sellers", "label": "Best Sellers link" },
    { "type": "url", "id": "url_quiz", "label": "Quiz page link" },
    { "type": "url", "id": "url_gift", "label": "Gift card link" },
    { "type": "header", "content": "Routine links" },
    { "type": "url", "id": "url_hydra", "label": "Hydration collection" },
    { "type": "url", "id": "url_imp", "label": "Anti-blemish collection" },
    { "type": "url", "id": "url_age", "label": "Anti-age collection" },
    { "type": "url", "id": "url_glass", "label": "Glass Skin collection" },
    { "type": "url", "id": "url_sens", "label": "Sensitive collection" },
    { "type": "header", "content": "Category links" },
    { "type": "url", "id": "url_cleansers", "label": "Cleansers collection" },
    { "type": "url", "id": "url_toners", "label": "Toners collection" },
    { "type": "url", "id": "url_serums", "label": "Serums collection" },
    { "type": "url", "id": "url_creams", "label": "Creams collection" },
    { "type": "url", "id": "url_spf", "label": "SPF collection" },
    { "type": "url", "id": "url_masks", "label": "Masks collection" },
    { "type": "url", "id": "url_lips", "label": "Lips collection" },
    { "type": "url", "id": "url_hair", "label": "Hair collection" },
    { "type": "url", "id": "url_base", "label": "Base/Foundation collection" }
  ]
}
{% endschema %}
