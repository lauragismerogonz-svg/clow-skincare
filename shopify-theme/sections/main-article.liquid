<article class="page-width" style="padding: 5rem 1.5rem; max-width: 800px">
  <div class="article__meta">
    <a class="btn btn--text" href="{{ blog.url }}">{% render 'icon', icon: 'arrow-left', size: 15 %} {{ blog.title }}</a>
  </div>
  <h1 class="article__title" style="font-size: clamp(1.8rem,4vw,2.8rem); margin: 1.5rem 0 0.5rem">{{ article.title }}</h1>
  <div class="article__date eyebrow" style="margin-bottom: 2rem">{{ article.published_at | date: '%d %B %Y' }}</div>
  {%- if article.image -%}
    <img src="{{ article.image | image_url: width: 1200 }}" alt="{{ article.image.alt | escape }}" width="1200" height="600" style="width:100%;height:auto;border-radius:12px;margin-bottom:2rem" loading="eager">
  {%- endif -%}
  <div class="rte" style="line-height:1.75;font-size:1.05rem">{{ article.content }}</div>
</article>

{% schema %}
{ "name": "Article" }
{% endschema %}
