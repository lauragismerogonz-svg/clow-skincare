{%- liquid
  assign product = product
  assign current_variant = product.selected_or_first_available_variant
  assign points = product.price | divided_by: 100
  assign in_collection = product.collections.first
-%}
<section class="pdp" data-pdp>
  <div class="pdp__inner">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">{{ 'product.breadcrumb_home' | t }}</a>
      <span class="breadcrumb__sep">/</span>
      {%- if in_collection != blank -%}
        <a href="{{ in_collection.url }}">{{ in_collection.title }}</a>
        <span class="breadcrumb__sep">/</span>
      {%- endif -%}
      <span>{{ product.title }}</span>
    </nav>

    <div class="pdp__grid">
      {%- comment -%} Gallery {%- endcomment -%}
      <div class="pdp__gallery">
        <div class="pdp__main-img" data-pdp-main>
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 900 }}" alt="{{ product.featured_image.alt | default: product.title | escape }}" width="900" height="900" loading="eager">
          {%- endif -%}
        </div>
        {%- if product.images.size > 1 -%}
          <div class="pdp__thumbs">
            {%- for image in product.images -%}
              <button class="pdp__thumb{% if forloop.first %} is-active{% endif %}" data-pdp-thumb data-full="{{ image | image_url: width: 900 }}" aria-label="{{ 'product.view' | t }}">
                <img src="{{ image | image_url: width: 160 }}" alt="" width="160" height="160" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Details {%- endcomment -%}
      <div class="pdp__details">
        {%- if product.vendor != blank -%}<div class="pdp__brand">{{ product.vendor }}</div>{%- endif -%}
        <h1 class="pdp__title">{{ product.title }}</h1>

        <div class="pdp__stars" aria-label="4.8 / 5">
          {% render 'icon', icon: 'star-fill', size: 15 %}{% render 'icon', icon: 'star-fill', size: 15 %}{% render 'icon', icon: 'star-fill', size: 15 %}{% render 'icon', icon: 'star-fill', size: 15 %}{% render 'icon', icon: 'star-fill', size: 15 %}
          <span class="muted">4,8 · {{ 'product.reviews' | t }}</span>
        </div>

        <div class="pdp__price" data-pdp-price>
          {% render 'price', variant: current_variant, show_badge: true %}
        </div>

        <form data-add-form action="/cart/add" method="post">
          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <div class="pdp__variant-group" data-option-index="{{ option.position }}">
                <div class="pdp__variant-label">{{ option.name }}</div>
                <div class="variant-pills">
                  {%- for value in option.values -%}
                    <button type="button"
                      class="variant-pill{% if option.selected_value == value %} is-active{% endif %}"
                      data-value="{{ value | escape }}">{{ value }}</button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          {%- endunless -%}

          <input type="hidden" name="id" value="{{ current_variant.id }}">

          <div class="pdp__buy">
            <div class="qty-stepper qty-stepper--lg" data-stepper>
              <button type="button" data-stepper-dec aria-label="minus">{% render 'icon', icon: 'minus', size: 16 %}</button>
              <input class="visually-hidden" type="number" name="quantity" value="1" min="1">
              <span class="qty-stepper__val" data-stepper-val>1</span>
              <button type="button" data-stepper-inc aria-label="plus">{% render 'icon', icon: 'plus', size: 16 %}</button>
            </div>
            <button type="submit" class="btn btn--lg btn--full{% unless product.available %} btn--disabled{% endunless %}">
              <span data-btn-label>{% if product.available %}{{ 'product.add_to_cart' | t }}{% else %}{{ 'product.sold_out' | t }}{% endif %}</span>
            </button>
          </div>
        </form>

        <div class="pdp__points">
          {% render 'icon', icon: 'sparkles', size: 16 %}
          {{ 'product.points_note' | t: points: points }}
        </div>

        {%- comment -%} Accordions {%- endcomment -%}
        <div class="accordion">
          <div class="accordion__item is-open">
            <button class="accordion__trigger" type="button" aria-expanded="true">
              {{ 'product.description' | t }} <span class="acc-icon">{% render 'icon', icon: 'chevron-down', size: 18 %}</span>
            </button>
            <div class="accordion__panel"><div class="accordion__content">{{ product.description }}</div></div>
          </div>

          {%- assign ingredients = product.metafields.clow.ingredients -%}
          <div class="accordion__item">
            <button class="accordion__trigger" type="button" aria-expanded="false">
              {{ 'product.ingredients' | t }} <span class="acc-icon">{% render 'icon', icon: 'chevron-down', size: 18 %}</span>
            </button>
            <div class="accordion__panel"><div class="accordion__content">
              {%- if ingredients != blank -%}{{ ingredients }}{%- else -%}{{ product.metafields.custom.ingredients | default: '—' }}{%- endif -%}
            </div></div>
          </div>

          {%- assign how_to = product.metafields.clow.how_to -%}
          <div class="accordion__item">
            <button class="accordion__trigger" type="button" aria-expanded="false">
              {{ 'product.how_to' | t }} <span class="acc-icon">{% render 'icon', icon: 'chevron-down', size: 18 %}</span>
            </button>
            <div class="accordion__panel"><div class="accordion__content">
              {%- if how_to != blank -%}{{ how_to }}{%- else -%}{{ product.metafields.custom.how_to | default: '—' }}{%- endif -%}
            </div></div>
          </div>
        </div>
      </div>
    </div>

    {%- comment -%} Related {%- endcomment -%}
    {%- if in_collection != blank -%}
      <div style="margin-top:72px">
        <div class="section-head"><h2 class="section-head__title">{{ 'product.related' | t }}</h2></div>
        <div class="product-grid product-grid--4">
          {%- assign shown = 0 -%}
          {%- for related in in_collection.products -%}
            {%- if related.id != product.id and shown < 4 -%}
              {% render 'product-card', product: related %}
              {%- assign shown = shown | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>

  <script type="application/json" data-variant-json>
    {{ product.variants | json }}
  </script>
</section>

{% schema %}
{
  "name": "Product",
  "settings": [
    { "type": "checkbox", "id": "show_related", "label": "Show related products", "default": true }
  ]
}
{% endschema %}
